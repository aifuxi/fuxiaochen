{
  "name": "fuxiaochen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "cross-env NODE_ENV=production next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "build:analyzer": "cross-env ANALYZE=true next build",
    "prepare": "husky",
    "lint": "oxlint --quiet",
    "lint:fix": "oxlint --fix --quiet",
    "lint:inspect": "oxlint --print-config",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "commit": "cz",
    "commit:retry": "cz --retry"
  },
  "dependencies": {
    "@bytemd/plugin-breaks": "^1.22.0",
    "@bytemd/plugin-frontmatter": "^1.22.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight-ssr": "^1.22.0",
    "@bytemd/plugin-medium-zoom": "^1.22.0",
    "@bytemd/react": "^1.22.0",
    "@ebay/nice-modal-react": "^1.2.13",
    "@hookform/resolvers": "^5.2.2",
    "@next/bundle-analyzer": "16.2.4",
    "@next/third-parties": "16.2.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "ali-oss": "^6.23.0",
    "better-auth": "^1.4.18",
    "bytemd": "^1.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "es-toolkit": "^1.39.10",
    "framer-motion": "^12.33.0",
    "globals": "^16.3.0",
    "lucide-react": "^0.562.0",
    "next": "16.2.4",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "proxy-agent": "^6.5.0",
    "query-string": "^9.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.71.1",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@iconify-json/skill-icons": "^1.2.3",
    "@iconify/tailwind4": "^1.2.0",
    "@prisma/client": "^7.3.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/ali-oss": "^6.23.2",
    "@types/node": "22.19.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.14",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "postcss": "^8.5.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.11",
    "tailwindcss-debug-screens": "^3.0.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,mts,cts,jsx,ts,tsx}": [
      "oxlint --fix --quiet --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{css,scss,less,md,mdx,json,jsonc,json5,yaml,yml,toml,html,graphql,gql,hbs}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">= 20",
    "pnpm": ">= 9"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
