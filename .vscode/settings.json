{
  // 搜索时排除的目录和文件
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.trae": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  // 保存时格式化代码
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.typeAware": true,
  // 配置 tailwindcss 的类函数
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "'([^']*)'"], // 识别 cn() 中的类名
    ["cva\\(([^)]*)\\)", "'([^']*)'"], // 识别 cva() 中的类名
    ["clsx\\(([^)]*)\\)", "'([^']*)'"] // 识别 clsx() 中的类名
  ],
  "css.customData": [".vscode/tailwind.json"] // v4 自定义 at-rules 识别
}
