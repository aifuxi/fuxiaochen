# Database
DATABASE_HOST="localhost"
DATABASE_PORT="5400"
DATABASE_USER="postgres"
DATABASE_PASSWORD="your_password"
DATABASE_DBNAME="fuxiaochen_dev"
DATABASE_NAME="fuxiaochen_dev"
DATABASE_URL="postgresql://postgres:your_password@localhost:5400/fuxiaochen_dev"

# OSS
OSS_ACCESS_KEY_ID="your_access_key_id"
OSS_ACCESS_KEY_SECRET="your_access_key_secret"
OSS_REGION="cn-shanghai"
OSS_BUCKET="your_bucket"
OSS_UPLOAD_DIR="fuxiaochen_dev"

# Better Auth
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
BETTER_AUTH_SECRET="your_better_auth_secret"
BETTER_AUTH_URL="http://localhost:3000"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Build tooling
ANALYZE="false"

# Logging
LOG_LEVEL="info"

# Local API debugging
# Adds mock latency to /api/admin/** and /api/public/** only. Keep 0 in production.
API_MOCK_DELAY_MS="0"
# Prints structured API timing logs to stdout through Pino when set to true.
API_TIMING_LOGS="false"
# Persists slow or failed API timing logs to PostgreSQL when set to true.
API_TIMING_DB_LOGS="false"
# Minimum total request duration, in milliseconds, required for DB persistence.
# Failed requests with status >= 400 are persisted regardless of this threshold.
API_TIMING_DB_SLOW_MS="1000"
# Number of days to keep persisted API timing logs before best-effort cleanup.
API_TIMING_LOG_RETENTION_DAYS="30"
